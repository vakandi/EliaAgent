{
  "name": "elia-ui",
  "version": "1.0.0",
  "description": "EliaUI - ntfy.sh notification overlay",
  "main": "src/main.js",
  "scripts": {
    "start": "node ./node_modules/electron/cli.js .",
    "set-position": "node ./node_modules/electron/cli.js . --set-position",
    "start:dev": "node ./node_modules/electron/cli.js . --remote-debugging-port=9222 --inspect=9223",
    "start:debug": "ELECTRON_ENABLE_LOGGING=1 node ./node_modules/electron/cli.js . --remote-debugging-port=9222 --inspect=9223",
    "install-deps": "npm install"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "electron": "^33.0.0",
    "node-fetch": "^2.7.0"
  }
}
